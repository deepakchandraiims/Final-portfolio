# ── Supabase (content DB + file storage) — put YOUR account's values here ──
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=portfolio-files

# ── Admin ──
# Password is "admin" by default if you leave this unset. Set your own
# before going live — see the Connections tab in /admin for a live check.
ADMIN_PASSWORD=
# Optional: a stable secret for signing admin session cookies. If unset,
# one is derived from ADMIN_PASSWORD automatically (still secure), but
# setting your own means sessions survive an ADMIN_PASSWORD change.
ADMIN_SESSION_SECRET=

# ── Google Drive attach (optional) — both are PUBLIC/client-side values,
# safe to expose; restrict them to your domain in Google Cloud Console. ──
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_API_KEY=

# ── Public site URL (metadata / OG / sitemap) ──
NEXT_PUBLIC_SITE_URL=https://deepak.finance

# ── Investment Lab: market data (optional) ──
# Provider is swappable without touching code — everything goes through
# lib/market-data.js. Leave unset to run the Lab on admin-entered prices.
# Options: fmp | finnhub | twelvedata | alphavantage | yahoo | none
MARKET_DATA_PROVIDER=none
MARKET_DATA_API_KEY=

# Secret for the daily valuation snapshot cron (Vercel Cron -> POST /api/lab/snapshot)
CRON_SECRET=
